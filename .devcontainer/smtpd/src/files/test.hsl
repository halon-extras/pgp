MYLXiY/jaRdbAiK/F7X/cYcgtxYAA8hEptD3Cu3+Dg==
=cAcn
-----END PGP PUBLIC KEY BLOCK-----'']];

$encrypted = pgp_encrypt($message, [$user1pubkeyring], [$user1privkeyring], ["profile" => "default", "detached" => true]);
$result = pgp_decrypt($encrypted["data"], [$user1privkeyring], [$user1pubkeyring], ["profile" => "default", "signature" => $encrypted["signature"]]);

if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 5 (Sign + Encrypt & Decrypt + Verify (Detached)): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 5 (Sign + Encrypt & Decrypt + Verify (Detached)):\tOK";

// Test 6 (Sign & Verify (No matching signature))
$expect = ["result"=>false,"error"=>"Signature Verification Error: No matching signature"];

$signed = pgp_sign($message, [$user1privkeyring]);
$result = pgp_verify($signed["data"], [$user2pubkeyring]);

if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 6 (Sign & Verify (No matching signature)): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 6 (Sign & Verify (No matching signature)):\t\tOK";

// Test 7 (Encrypt & Decrypt (Multiple keys))
