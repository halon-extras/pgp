EPGl+Kn/XCQaCRkA/3LIxSlDRZ638mCSsG8cLllEElfGOjTbnEvuJ8AA/w95AP0Z
MYLXiY/jaRdbAiK/F7X/cYcgtxYAA8hEptD3Cu3+Dg==
=cAcn
-----END PGP PUBLIC KEY BLOCK-----'']];

$signed = pgp_sign($message, [$user1privkeyring], ["detached" => true]);
$result = pgp_verify($message, [$user1pubkeyring], ["signature" => $signed["data"]]);

if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 2 (Sign & Verify (Detached)): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 2 (Sign & Verify (Detached)):\t\t\tOK";

// Test 3 (Encrypt & Decrypt)
$expect = ["result"=>true,"data"=>"Hello World"];

$encrypted = pgp_encrypt($message, [$user1pubkeyring], none, ["profile" => "default"]);
$result = pgp_decrypt($encrypted["data"], [$user1privkeyring], none, ["profile" => "default"]);

if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 3 (Encrypt & Decrypt): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 3 (Encrypt & Decrypt):\t\t\t\tOK";

// Test 4 (Sign + Encrypt & Decrypt + Verify)
$expect = ["result"=>true, "data"=>"Hello World","signers"=>[0=>''-----BEGIN PGP PUBLIC KEY BLOCK-----

xjMEaYRHMxYJKwYBBAHaRw8BAQdAeys1HObh1T/52MyemnXSSBKGcGroexC+HvTf
