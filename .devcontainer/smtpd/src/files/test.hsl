import { pgp_sign, pgp_verify, pgp_encrypt, pgp_decrypt } from "extras://pgp";

import $allpubkeyring from "txt!all.pub.asc";
import $allprivkeyring from "txt!all.priv.asc";
import $user1pubkeyring from "txt!user1.pub.asc";
import $user1privkeyring from "txt!user1.priv.asc";
import $user2pubkeyring from "txt!user2.pub.asc";
import $user2privkeyring from "txt!user2.priv.asc";

$message = "Hello World";

// Test 1 (Sign & Verify (Inline))
$expect = ["result"=>true,"data"=>"Hello World"];

$signed = pgp_sign($message, [$user1privkeyring]);
$result = pgp_verify($signed["data"], [$user1pubkeyring]);

if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 1 (Sign & Verify (Inline)): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 1 (Sign & Verify (Inline)):\t\t\tOK";

// Test 2 (Sign & Verify (Detached))
$expect = ["result"=>true];

$signed = pgp_sign($message, [$user1privkeyring], ["detached" => true]);
$result = pgp_verify($message, [$user1pubkeyring], ["signature" => $signed["data"]]);

if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 2 (Sign & Verify (Detached)): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 2 (Sign & Verify (Detached)):\t\t\tOK";

// Test 3 (Encrypt & Decrypt)
$expect = ["result"=>true,"data"=>"Hello World"];

$encrypted = pgp_encrypt($message, [$user1pubkeyring], none, ["profile" => "default"]);
$result = pgp_decrypt($encrypted["data"], [$user1privkeyring], none, ["profile" => "default"]);

if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 3 (Encrypt & Decrypt): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 3 (Encrypt & Decrypt):\t\t\t\tOK";

// Test 4 (Sign + Encrypt & Decrypt + Verify)
$expect = ["result"=>true, "data"=>"Hello World"];

$encrypted = pgp_encrypt($message, [$user1pubkeyring], [$user1privkeyring], ["profile" => "default"]);
$result = pgp_decrypt($encrypted["data"], [$user1privkeyring], [$user1pubkeyring], ["profile" => "default"]);

if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 4 (Sign + Encrypt & Decrypt + Verify): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 4 (Sign + Encrypt & Decrypt + Verify):\t\tOK";

// Test 5 (Sign + Encrypt & Decrypt + Verify (Detached))
$expect = ["result"=>true, "data"=>"Hello World"];

$encrypted = pgp_encrypt($message, [$user1pubkeyring], [$user1privkeyring], ["profile" => "default", "detached" => true]);
$result = pgp_decrypt($encrypted["data"], [$user1privkeyring], [$user1pubkeyring], ["profile" => "default", "signature" => $encrypted["signature"]]);

if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 5 (Sign + Encrypt & Decrypt + Verify (Detached)): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 5 (Sign + Encrypt & Decrypt + Verify (Detached)):\tOK";

// Test 6 (Sign & Verify (No matching signature))
$expect = ["result"=>false,"error"=>"Signature Verification Error: No matching signature"];

$signed = pgp_sign($message, [$user1privkeyring]);
$result = pgp_verify($signed["data"], [$user2pubkeyring]);

if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 6 (Sign & Verify (No matching signature)): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 6 (Sign & Verify (No matching signature)):\t\tOK";

// Test 7 (Encrypt & Decrypt (Multiple keys))
$expect = ["result"=>true, "data"=>"Hello World"];

$encrypted = pgp_encrypt($message, [$user1pubkeyring, $user2pubkeyring], [$user1privkeyring, $user2privkeyring], ["profile" => "default"]);
$result = pgp_decrypt($encrypted["data"], [$user1privkeyring, $user2privkeyring], [$user1pubkeyring, $user2pubkeyring], ["profile" => "default"]);

if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 7 (Encrypt & Decrypt (Multiple keys)): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 7 (Encrypt & Decrypt (Multiple keys)):\t\tOK";

// Test 8 (Sign with wrong type of key)
$expect = ["result"=>false,"error"=>"gopenpgp: signing entity does not contain unencrypted private key"];

$result = pgp_sign($message, [$user1pubkeyring]);

if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 8 (Sign with wrong type of key): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 8 (Sign with wrong type of key):\t\t\tOK";

// Test 9 (Encrypt & Decrypt (Multiple keys in same ring))
$expect = ["result"=>true, "data"=>"Hello World"];

$encrypted = pgp_encrypt($message, [$allpubkeyring], [$allprivkeyring], ["profile" => "default"]);
$result = pgp_decrypt($encrypted["data"], [$allprivkeyring], [$allpubkeyring], ["profile" => "default"]);

if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 9 (Encrypt & Decrypt (Multiple keys in same ring)): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 9 (Encrypt & Decrypt (Multiple keys in same ring)):OK";