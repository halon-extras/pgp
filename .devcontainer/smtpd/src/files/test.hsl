import { pgp_sign, pgp_verify, pgp_encrypt, pgp_decrypt } from "extras://pgp";

import $allpubkeyring from "txt!all.pub.asc";
import $allprivkeyring from "txt!all.priv.asc";
import $user1pubkeyring from "txt!user1.pub.asc";
import $user1privkeyring from "txt!user1.priv.asc";
import $user2pubkeyring from "txt!user2.pub.asc";
import $user2privkeyring from "txt!user2.priv.asc";

$message = "Hello World";

// Test 1 (Sign & Verify (Inline))
$expect = ["result"=>true,"data"=>"Hello World","signers"=>[0=>''-----BEGIN PGP PUBLIC KEY BLOCK-----

xjMEaYRHMxYJKwYBBAHaRw8BAQdAeys1HObh1T/52MyemnXSSBKGcGroexC+HvTf
D+83WeTNH0phbmUgRG9lIDxqYW5lLmRvZUBleGFtcGxlLmNvbT7CkwQTFgoAOxYh
BLLciu3Pt1+M33uRHPGl+Kn/XCQaBQJphEczAhsDBQsJCAcCAiICBhUKCQgLAgQW
AgMBAh4HAheAAAoJEPGl+Kn/XCQazm4A/A8hXrCwRnTdAh25IruJtH6SNnljznQX
M3JUg6PYx61MAQCo9yo50vjAUXE7YDLSpoF8imtXxaurEX/l2Yyvc84bAs44BGmE
