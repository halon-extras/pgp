MYLXiY/jaRdbAiK/F7X/cYcgtxYAA8hEptD3Cu3+Dg==
=cAcn
-----END PGP PUBLIC KEY BLOCK-----'']];

$encrypted = pgp_encrypt($message, [$user1pubkeyring], [$user1privkeyring], ["profile" => "default"]);
$result = pgp_decrypt($encrypted["data"], [$user1privkeyring], [$user1pubkeyring], ["profile" => "default"]);

if (json_encode($result) !== json_encode($expect))
    throw Exception("Test 4 (Sign + Encrypt & Decrypt + Verify): FAILED\nRESULT($result)\nEXPECT($expect)");
echo "Test 4 (Sign + Encrypt & Decrypt + Verify):\t\tOK";

// Test 5 (Sign + Encrypt & Decrypt + Verify (Detached))
$expect = ["result"=>true, "data"=>"Hello World","signers"=>[0=>''-----BEGIN PGP PUBLIC KEY BLOCK-----

xjMEaYRHMxYJKwYBBAHaRw8BAQdAeys1HObh1T/52MyemnXSSBKGcGroexC+HvTf
